# --- Telegram ---
TELEGRAM_BOT_TOKEN=
# Comma-separated list of telegram user IDs allowed to manage inventory
TELEGRAM_ALLOWED_USER_IDS=

# --- AI brain (Gemini) ---
GEMINI_API_KEY=

# --- Image hosting (Cloudinary) ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Database ---
# Default: SQLite at backend/data/inventory.db
DATABASE_URL=sqlite:///./data/inventory.db

# --- Backend API ---
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
# CORS origin for the Next.js frontend
FRONTEND_ORIGIN=http://localhost:3000

# --- Optional: Facebook Marketplace ---
FB_CATALOG_ID=
FB_ACCESS_TOKEN=
